<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml  —  ML-T1 Chromatic Tuner
    Pivot na BORDA INFERIOR do display (54, 76).
    Agulha aponta para CIMA em direção à escala.
    Posição -20°: haste sobe para esquerda, ponta toca a escala.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ══ DISPLAY ══════════════════════════════════════════ -->
    <path android:fillColor="#0A0500"
        android:pathData="M20,16 L88,16 L88,78 L20,78 Z"/>
    <path android:fillColor="#5A2000"
        android:pathData="M22,18 L86,18 L86,76 L22,76 Z"/>
    <!-- gradiente âmbar radial simulado -->
    <path android:fillColor="#B84E00"
        android:pathData="M54,76 m-28,0 a28,36 0 1,1 56,0"/>
    <path android:fillColor="#D06000"
        android:pathData="M54,76 m-14,0 a14,24 0 1,1 28,0"/>

    <!-- ══ BADGE CENT ════════════════════════════════════════ -->
    <path android:fillColor="#1A6A1A"
        android:pathData="M72,21 L84,21 L84,27 L72,27 Z"/>
    <path android:strokeColor="#5AEE5A" android:strokeWidth="0.9"
        android:fillColor="#00000000"
        android:pathData="M74,24 L82,24"/>

    <!-- ══ ARCO GUIA ═════════════════════════════════════════
         Pivot em (54,76), raio ~36.
         Arco de ~-130° a ~-50° (abertura de 80° para cada lado)
    ════════════════════════════════════════════════════════ -->
    <path android:strokeColor="#2A1000" android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:pathData="M22,68 Q54,32 86,68"/>

    <!-- ══ TICKS ══════════════════════════════════════════════
         Pivot (54,76). Raio externo ~38, interno ~32.
         Ângulos: theta = -90 + (cent/50)*82
         -40: -155.6°  -25: -131°  -10: -106.4°
           0:  -90°    +10:  -73.6°  +25: -49°  +40: -24.4°
    ════════════════════════════════════════════════════════ -->

    <!-- -40 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M19.5,59.8 L23.2,65.0"/>
    <!-- -25 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:pathData="M28.4,45.6 L31.8,50.6"/>
    <!-- -10 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M43.4,38.0 L45.4,43.6"/>
    <!-- 0 (centro — mais grosso e longo) -->
    <path android:strokeColor="#4A2000" android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M54,38 L54,46"/>
    <!-- +10 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M64.6,38.0 L62.6,43.6"/>
    <!-- +25 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:pathData="M79.6,45.6 L76.2,50.6"/>
    <!-- +40 -->
    <path android:strokeColor="#2A1200" android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M88.5,59.8 L84.8,65.0"/>

    <!-- ══ PIVOT em (54, 76) ══════════════════════════════════ -->
    <path android:fillColor="#0F0800"
        android:pathData="M50,76 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"/>
    <path android:fillColor="#1A0A00"
        android:pathData="M51.5,76 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"/>
    <path android:fillColor="#BB5500"
        android:pathData="M52.8,76 a1.2,1.2 0 1,0 2.4,0 a1.2,1.2 0 1,0 -2.4,0"/>

    <!-- ══ AGULHA — posição -20° ══════════════════════════════
         Pivot: (54, 76)
         theta(-20) = -90 + (-20/50)*82 = -122.8°
         cos(-122.8°) = -0.5402   sin(-122.8°) = -0.8415

         PONTA (raio 36, direção do ângulo → para CIMA):
           tipX = 54 + 36 * cos(-122.8°) = 54 - 19.45 = 34.55
           tipY = 76 + 36 * sin(-122.8°) = 76 - 30.29 = 45.71

         BASE (raio 5, direção oposta → para BAIXO, ainda dentro do display):
           baseX = 54 + 5 * cos(57.2°)  = 54 + 2.71  = 56.71
           baseY = 76 + 5 * sin(57.2°)  = 76 + 4.20  = 80.20
           → clampado a 76 (borda inferior do display)
    ════════════════════════════════════════════════════════ -->

    <!-- Haste: nasce no pivot, vai para cima-esquerda -->
    <path
        android:strokeColor="#F0E8D0"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M54,76 L34.6,45.7"/>

    <!-- Triângulo na ponta — apontando para cima/esquerda -->
    <path
        android:fillColor="#F0E8D0"
        android:pathData="M34.6,41.5 L30.8,48.0 L38.4,48.0 Z"/>

    <!-- ══ PARAFUSOS ══════════════════════════════════════════ -->
    <path android:fillColor="#181818"
        android:pathData="M22,18 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"/>
    <path android:strokeColor="#3A3A3A" android:strokeWidth="0.7"
        android:strokeLineCap="round" android:pathData="M22.8,18 L26,18"/>

    <path android:fillColor="#181818"
        android:pathData="M83.6,18 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"/>
    <path android:strokeColor="#3A3A3A" android:strokeWidth="0.7"
        android:strokeLineCap="round" android:pathData="M84.4,18 L87.6,18"/>

    <path android:fillColor="#181818"
        android:pathData="M22,76 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"/>
    <path android:strokeColor="#3A3A3A" android:strokeWidth="0.7"
        android:strokeLineCap="round" android:pathData="M22.8,76 L26,76"/>

    <path android:fillColor="#181818"
        android:pathData="M83.6,76 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"/>
    <path android:strokeColor="#3A3A3A" android:strokeWidth="0.7"
        android:strokeLineCap="round" android:pathData="M84.4,76 L87.6,76"/>

    <!-- ══ ABAIXO DO DISPLAY ══════════════════════════════════ -->
    <path android:strokeColor="#D4A85A" android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:pathData="M28,85 L80,85"/>
    <path android:strokeColor="#5A3A10" android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M38,90 L70,90"/>
    <path android:fillColor="#1A8A1A"
        android:pathData="M52,96 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0"/>

</vector>